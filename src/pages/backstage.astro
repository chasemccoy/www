---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogPostPreview from '../components/BlogPostPreview.vue';
import { getPosts, getFeaturedPosts, getYears, getBlogroll } from '../utils/collections';
import { titleize } from '../utils/filters';

const blogroll = await getBlogroll();
const allPosts = await getPosts();
const hiddenPosts = allPosts.filter(p => p.data.hidden).reverse();
const featuredPosts = await getFeaturedPosts();
const years = await getYears();
---
<BaseLayout
  title="Backstage"
  templateClass="Blog"
  featuredPosts={featuredPosts}
  years={years}
  blogroll={blogroll}
>
  <div class="prose">
    <div class="Breadcrumbs mb-12">
      <a href="/" class="bold">Home</a>
    </div>

    <h1 class="font-header">
      <a href="/backstage" class="unstyled">Backstage</a>
    </h1>

    <h2>Drafts</h2>

    <div class="flex flex-column" style="gap: 1em;">
      {hiddenPosts.map(post => (
        <BlogPostPreview
          title={post.data.title || titleize(post.id.split('/').pop() || post.id)}
          date={post.date!}
          permalink={post.permalink}
        />
      ))}
    </div>
  </div>
</BaseLayout>
