---
import BaseLayout from './BaseLayout.astro';
import ReplyBadge from '../components/ReplyBadge.vue';
import PostNavigation from '../components/PostNavigation.vue';
import { getAdjacentPosts, getPostDisplayTitle } from '../utils';
import { getCollection } from 'astro:content';

interface Props {
  title?: string;
  date: Date | string;
  postId: string;
}

const { title, date, postId } = Astro.props;
const postTitle = getPostDisplayTitle({ title, date });

const allPosts = await getCollection('posts');
const { previous: previousPost, next: nextPost } = getAdjacentPosts(allPosts, postId);

let headerHtml = '';
if (title) {
  const currentPost = allPosts.find(p => p.id === postId);
  const permalink = currentPost?.data.permalink ?? '#';
  headerHtml = `<h1 class="font-header"><a href="${permalink}" class="unstyled">${title}</a></h1>`;
}
---
<BaseLayout
  title={title}
  templateClass="blog post"
  date={date}
  header={headerHtml}
>
  <article class="Article prose">
    <slot />
  </article>

  <ReplyBadge postTitle={postTitle} />

  <PostNavigation previousPost={previousPost} nextPost={nextPost} />
</BaseLayout>
