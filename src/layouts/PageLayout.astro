---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title?: string;
  description?: string;
  templateClass?: string;
  js?: string;
  header?: string;
}

const { title, description, templateClass, js, header } = Astro.props;
const headerHtml = header || (title ? `<h1 class="font-header">${title}</h1>` : undefined);
---
<BaseLayout
  title={title}
  description={description}
  templateClass={templateClass}
  js={js}
  header={headerHtml}
>
  <article class="Article prose">
    <slot />
  </article>
</BaseLayout>
