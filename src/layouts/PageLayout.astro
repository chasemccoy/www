---
import BaseLayout from './BaseLayout.astro';
import { getBlogroll } from '../utils/collections';

interface Props {
  title?: string;
  description?: string;
  templateClass?: string;
  js?: string;
  header?: string;
  featuredPosts?: any[];
  postsByYear?: Record<string, any[]>;
}

const { title, description, templateClass, js, header, featuredPosts = [], postsByYear = {} } = Astro.props;
const blogroll = await getBlogroll();
---
<BaseLayout
  title={title}
  description={description}
  templateClass={templateClass}
  js={js}
  header={header}
  featuredPosts={featuredPosts}
  postsByYear={postsByYear}
  blogroll={blogroll}
>
  <slot />
</BaseLayout>
