---
import BaseLayout from './BaseLayout.astro';
import { getBlogroll } from '../utils/collections';

interface Props {
  title?: string;
  description?: string;
  templateClass?: string;
  js?: string;
  header?: string;
  featuredPosts?: any[];
  years?: string[];
}

const { title, description, templateClass, js, header, featuredPosts = [], years = [] } = Astro.props;
const blogroll = await getBlogroll();
const headerHtml = header || (title ? `<h1 class="font-header">${title}</h1>` : undefined);
---
<BaseLayout
  title={title}
  description={description}
  templateClass={templateClass}
  js={js}
  header={headerHtml}
  featuredPosts={featuredPosts}
  years={years}
  blogroll={blogroll}
>
  <article class="Article prose">
    <slot />
  </article>
</BaseLayout>
